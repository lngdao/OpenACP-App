{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenACP",
  "identifier": "com.openacp.desktop",
  "version": "../package.json",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenACP",
        "width": 1400,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "active": true,
    "targets": "all"
  }
}
