{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@openacp/util/*": ["./src/util/src/*"]
    }
  },
  "include": ["src/openacp", "src/onboarding", "src/platform", "src/lib"],
  "exclude": ["src/ui", "src/util", "src/app", "src/openacp-sdk"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
